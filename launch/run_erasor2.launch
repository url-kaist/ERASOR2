<launch>

<arg name="target_seq" default="02"/>

<group if="$(eval arg('target_seq') =='00')">
    <rosparam command="load" file="$(find erasor2)/config/seq_00.yaml" />
</group>
<group if="$(eval arg('target_seq') =='01')">
    <rosparam command="load" file="$(find erasor2)/config/seq_01.yaml" />
</group>
<group if="$(eval arg('target_seq') =='02')">
    <rosparam command="load" file="$(find erasor2)/config/seq_02.yaml" />
</group>
<group if="$(eval arg('target_seq') =='05')">
    <rosparam command="load" file="$(find erasor2)/config/seq_05.yaml" />
</group>
<group if="$(eval arg('target_seq') ==7)">
    <rosparam command="load" file="$(find erasor2)/config/seq_07.yaml" />
</group>

<node name="run_erasor2" pkg="erasor2" type="run_erasor2" output="screen" />

</launch>
