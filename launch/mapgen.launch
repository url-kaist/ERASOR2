<launch>

<arg name="seq" default="02"/>
<arg name="start_frame" default="860"/>
<arg name="end_frame" default="950" />

<rosparam command="load" file="$(find erasor2)/config/kitti_mapgen.yaml" />

<rosparam param="/dataloader/sequence" subst_value="true">"$(arg seq)"</rosparam>
<rosparam param="/start_frame" subst_value="true">$(arg start_frame)</rosparam>
<rosparam param="/end_frame" subst_value="true">$(arg end_frame)</rosparam>

<node name="mapgen" pkg="erasor2" type="mapgen" output="screen" />

<node name="rviz" pkg="rviz" type="rviz" args="-d $(find erasor2)/rviz/kitti_mapgen.rviz" />
</launch>
